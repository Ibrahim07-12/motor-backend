# Edit values sesuai lingkungan production Anda

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/motor-monitoring?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-production-change-this
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.vercel.app,https://komatsu-jaya.com

# Sensor data settings
MOTOR_ID_MAIN=motor_main_shakeout
DATA_RETENTION_DAYS=90

# Logging
LOG_LEVEL=info
